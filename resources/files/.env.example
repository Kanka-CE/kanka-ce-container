APP_NAME="Kanka Community Edition"
APP_ENV=local
APP_KEY=
APP_URL=http://localhost
APP_EMAIL=you@example.com
APP_PORT=8081
APP_USER_ID=1000
APP_GROUP_ID=1000
KANKA_CE_DATA=/opt/kanka-data

DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=kanka
DB_USERNAME=sail
DB_PASSWORD=password
DB_ROOT_PASSWORD=password

BROADCAST_DRIVER=reverb
CACHE_DRIVER=redis
CACHE_PREFIX=kanka
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_DRIVER=sync

REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

MAIL_DRIVER=log
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@kanka.io
MAIL_FROM_NAME="${APP_NAME}"

FONTAWESOME_KIT=

FILESYSTEM_DRIVER=minio
MINIO_URL=http://localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=8900
MINIO_ACCESS_KEY_ID=sail
MINIO_BUCKET=kanka
MINIO_PASSWORD=password

FRONT_DOMAIN=kanka.io

SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=true
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=password

REVERB_APP_ID=144165
REVERB_APP_KEY=kanka
REVERB_APP_SECRET=websockets123
REVERB_HOST=localhost
REVERB_SERVER_PORT=8080
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
