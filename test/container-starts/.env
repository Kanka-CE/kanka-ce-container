# ------------------------------------------------------------------
# Kanka Community Edition
# ------------------------------------------------------------------
# This file is for testing only, do NOT use it in porduction!

# -------------------------
# Application settings
# -------------------------
APP_NAME="Kanka Community Edition"

# Public URL where Kanka is reachable and contact information.
APP_URL=http://localhost
APP_EMAIL=you@example.com

# Allow users to self-register. Set to "false" to disable public signups.
APP_REGISTRATION_ENABLED=false

# Require an invitation to register. 
# When true, users need the invitation password set here.
APP_INVITATION_REQUIRED=false
APP_INVITATION_PASSWORD=

# Port the application listens on inside the container.
# Do not expose this port to the internet!
# Instead point a reverse proxy to this port.
APP_PORT=8081

# App environment. 
#   - Use "local" only for the set-up process and testing.
#   - Use "production" for live systems.
APP_ENV=local

# Application encryption key (should be generated automatically).
APP_KEY=

# Host path for persistent application data 
KANKA_CE_DATA=./data

FRONT_DOMAIN="${APP_URL}"
APP_DOMAIN="${APP_URL}"
API_DOMAIN="${APP_URL}"


# -------------------------
# Database
# -------------------------
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=kanka
DB_USERNAME=sail
DB_PASSWORD=3dd22912bf10ceee46bdef9092ebf3c0
DB_ROOT_PASSWORD=7137220bd8c9840024d633f9f3da8039


# -------------------------
# Cache, sessions, queues
# -------------------------
BROADCAST_DRIVER=null
CACHE_DRIVER=file
CACHE_PREFIX=kanka
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_DRIVER=sync


# -------------------------
# Frontend / icons
# -------------------------
# As we do not provide any link here, the fontawsome icons will not render correctly.
FONTAWESOME_KIT=


# -------------------------
# File storage
# -------------------------
# For large deployments, with many worlds you can consider MinIO instead. 
# Therefore see: .env.exmaple.minio
# However, for most usecases this should be fine
FILESYSTEM_DRIVER=public
